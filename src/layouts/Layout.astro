---
import Analytics from '@vercel/analytics/astro';
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/favicon.ico">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Inter:wght@100..900&display=swap" rel="stylesheet">

		<title>Sorin Raduta | Software Engineer</title>
		<meta name="description" content="I'm Sorin Raduta, a software engineer who builds systems that scale, using AI to move faster without cutting corners. Step into my interactive 3D office to see highlighted projects, a short bio, and ways to get in touch.">
		<link rel="canonical" href="https://sorinraduta.ro/" />
		<meta name="author" content="Sorin Raduta">
		<meta name="robots" content="index, follow">
		<meta name="theme-color" content="#008080">

		<meta property="og:type" content="website">
		<meta property="og:url" content="https://sorinraduta.ro/">
		<meta property="og:site_name" content="Sorin Raduta">
		<meta property="og:locale" content="en_US">
		<meta property="og:title" content="Sorin Raduta | Software Engineer">
		<meta property="og:description" content="I'm Sorin Raduta, a software engineer who builds systems that scale, using AI to move faster without cutting corners. Step into my interactive 3D office to see highlighted projects, a short bio, and ways to get in touch.">
		<meta property="og:image" content="https://sorinraduta.ro/assets/images/opengraph.jpg">
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="800">
		<meta property="og:image:alt" content="Interactive 3D office scene from Sorin Raduta's portfolio website">

		<meta name="twitter:card" content="summary_large_image">
		<meta name="twitter:url" content="https://sorinraduta.ro/">
		<meta name="twitter:title" content="Sorin Raduta | Software Engineer">
		<meta name="twitter:description" content="I'm Sorin Raduta, a software engineer who builds systems that scale, using AI to move faster without cutting corners. Step into my interactive 3D office to see highlighted projects, a short bio, and ways to get in touch.">
		<meta name="twitter:image" content="https://sorinraduta.ro/assets/images/opengraph.jpg">

		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Person",
					"@id": "https://sorinraduta.ro/#person",
					"name": "Sorin Raduta",
					"url": "https://sorinraduta.ro/",
					"jobTitle": "Software Engineer",
					"email": "mailto:sorinradutaa@gmail.com",
					"knowsAbout": ["JavaScript", "TypeScript", "React", "Node.js", "System Design", "Artificial Intelligence"],
					"sameAs": [
						"https://github.com/sorinraduta",
						"https://www.linkedin.com/in/sorinraduta/",
						"https://x.com/sorinraduta"
					]
				},
				{
					"@type": "WebSite",
					"@id": "https://sorinraduta.ro/#website",
					"url": "https://sorinraduta.ro/",
					"name": "Sorin Raduta | Software Engineer",
					"description": "Personal website and portfolio of Sorin Raduta, an interactive 3D office showcasing projects, bio, and contact information.",
					"author": { "@id": "https://sorinraduta.ro/#person" }
				}
			]
		})} />

		<Analytics />
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		overflow: hidden;
		height: 100%;
		width: 100%;
	}
</style>
